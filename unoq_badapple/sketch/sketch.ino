void drawLargeChar(int x, int y, char c, int scale) {
  if (c < 32 || c > 126) {
    c = '?';
  }
  const uint8_t *glyph = font5x7[c - 32];
  for (int col = 0; col < 5; ++col) {
    const uint8_t bits = glyph[col];
    for (int row = 0; row < 7; ++row) {
      if (bits & (1 << row)) {
        fillHeaderRect(x + col * scale, y + row * scale,
                       x + col * scale + scale - 1,
                       y + row * scale + scale - 1);
      }
    }
  }
}

void drawLargeString(int x, int y, const char *text, int scale) {
  while (*text) {
    drawLargeChar(x, y, *text++, scale);
    x += (5 + 1) * scale;
  }
}

void prepareHeader() {
  memset(headerBuffer, 0, sizeof(headerBuffer));
  drawLargeString(10, 1, "BAD APPLE!", 2);
}

size_t readExact(uint8_t *buffer, size_t count) {
  size_t total = 0;
  unsigned long deadline = millis() + FRAME_READ_GAP_TIMEOUT_MS;

  while (total < count) {
    const int available = Serial1.available();
    if (available > 0) {
      int remaining = available;
      while (remaining-- > 0 && total < count) {
        const int incoming = Serial1.read();
        if (incoming < 0) {
          break;
        }
        buffer[total++] = static_cast<uint8_t>(incoming);
      }
      deadline = millis() + FRAME_READ_GAP_TIMEOUT_MS;
      continue;
    }

    if (static_cast<long>(millis() - deadline) >= 0) {
      break;
    }
    delay(1);
  }

  return total;
}

bool waitForMagicAndCommand(char &commandOut) {
  static size_t matched = 0;
  static bool waitingForCommand = false;

  if (waitingForCommand) {
    if (Serial1.available() == 0) {
      return false;
    }
    commandOut = static_cast<char>(Serial1.read());
    waitingForCommand = false;
    return true;
  }

  while (Serial1.available() > 0) {
    const int incoming = Serial1.read();
    if (incoming < 0) {
      break;
    }
    if (incoming == PROTOCOL_MAGIC[matched]) {
      ++matched;
      if (matched == sizeof(PROTOCOL_MAGIC)) {
        matched = 0;
        if (Serial1.available() == 0) {
          waitingForCommand = true;
          return false;
        }
        commandOut = static_cast<char>(Serial1.read());
        return true;
      }
    } else {
      matched = (incoming == PROTOCOL_MAGIC[0]) ? 1 : 0;
    }
  }
  return false;
}

void handleFrame() {
  const size_t got = readExact(videoBuffer, sizeof(videoBuffer));
  if (got != sizeof(videoBuffer)) {
    Serial1.print("ERR SHORT ");
    Serial1.println(static_cast<unsigned long>(got));
    return;
  }
  if (!flushVideo()) {
    sendSerialLine("ERR DISPLAY");
    return;
  }
  ++displayedFrames;
  sendSerialValue("ACK ", displayedFrames);
}

void handleCommand(char command) {
  switch (command) {
    case 'Q':
      sendSerialLine("READY BADAPPLE_UNOQ");
      break;
    case 'F':
      handleFrame();
      break;
    case 'E':
      sendSerialValue("DONE ", displayedFrames);
      break;
    default:
      sendSerialLine("ERR CMD");
      break;
  }
}
}  // namespace

void setup() {
  Serial1.begin(SERIAL_BAUD);
  Serial1.setTimeout(1500);

  Wire.begin();
  Wire.setClock(400000);

  delay(50);
  if (!initDisplay()) {
    sendSerialLine("ERR INIT");
    return;
  }
  clearDisplay();
  prepareHeader();
  if (!flushHeader()) {
    sendSerialLine("ERR HEADER");
    return;
  }
  sendSerialLine("BOOT BADAPPLE_UNOQ");
}

void loop() {
  char command = 0;
  if (!waitForMagicAndCommand(command)) {
    delay(1);
    return;
  }
  handleCommand(command);
}
