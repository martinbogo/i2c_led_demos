namespace {
constexpr uint8_t OLED_ADDR = 0x3C;
constexpr uint8_t WIDTH = 128;
constexpr uint8_t HEIGHT = 64;
constexpr uint8_t HEADER_PAGES = 2;
constexpr uint8_t VIDEO_PAGES = 6;
constexpr size_t HEADER_BYTES = WIDTH * HEADER_PAGES;
constexpr size_t VIDEO_BYTES = WIDTH * VIDEO_PAGES;
constexpr size_t I2C_CHUNK = 31;
constexpr unsigned long SERIAL_BAUD = 460800;
constexpr unsigned long FRAME_READ_GAP_TIMEOUT_MS = 120;
constexpr char PROTOCOL_MAGIC[] = {'B', 'A', 'P', 'P'};

uint8_t headerBuffer[HEADER_BYTES] = {0};
uint8_t videoBuffer[VIDEO_BYTES] = {0};
uint32_t displayedFrames = 0;

void sendSerialLine(const char *message) {
  Serial1.println(message);
}

void sendSerialValue(const char *prefix, uint32_t value) {
  Serial1.print(prefix);
  Serial1.println(value);
}

bool sendCommandBytes(const uint8_t *bytes, size_t count) {
  Wire.beginTransmission(OLED_ADDR);
  Wire.write(0x00);
  for (size_t i = 0; i < count; ++i) {
    Wire.write(bytes[i]);
  }
  return Wire.endTransmission() == 0;
}

bool sendDataBytes(const uint8_t *bytes, size_t count) {
  while (count > 0) {
    const size_t chunk = count > I2C_CHUNK ? I2C_CHUNK : count;
    Wire.beginTransmission(OLED_ADDR);
    Wire.write(0x40);
    for (size_t i = 0; i < chunk; ++i) {
      Wire.write(bytes[i]);
    }
    if (Wire.endTransmission() != 0) {
      return false;
    }
    bytes += chunk;
    count -= chunk;
  }
  return true;
}

bool setWindow(uint8_t colStart, uint8_t colEnd, uint8_t pageStart, uint8_t pageEnd) {
  const uint8_t cmds[] = {0x21, colStart, colEnd, 0x22, pageStart, pageEnd};
  return sendCommandBytes(cmds, sizeof(cmds));
}

bool clearDisplay() {
  static uint8_t zeroPage[WIDTH] = {0};
  for (uint8_t page = 0; page < HEIGHT / 8; ++page) {
    if (!setWindow(0, WIDTH - 1, page, page)) {
      return false;
    }
    if (!sendDataBytes(zeroPage, sizeof(zeroPage))) {
      return false;
    }
  }
  return true;
}

bool initDisplay() {
  const uint8_t init[] = {
      0xAE, 0xD5, 0x80, 0xA8, 0x3F, 0xD3, 0x00, 0x40,
      0x8D, 0x14, 0x20, 0x00, 0xA1, 0xC8, 0xDA, 0x12,
      0x81, 0xCF, 0xD9, 0xF1, 0xDB, 0x40, 0xA4, 0xA6,
      0xAF,
  };
  return sendCommandBytes(init, sizeof(init));
}

bool flushHeader() {
  return setWindow(0, WIDTH - 1, 0, HEADER_PAGES - 1) && sendDataBytes(headerBuffer, sizeof(headerBuffer));
}

bool flushVideo() {
  return setWindow(0, WIDTH - 1, HEADER_PAGES, HEADER_PAGES + VIDEO_PAGES - 1) && sendDataBytes(videoBuffer, sizeof(videoBuffer));
}

void setHeaderPixel(int x, int y) {
  if (x < 0 || x >= WIDTH || y < 0 || y >= 16) {
    return;
  }
  headerBuffer[x + (y / 8) * WIDTH] |= static_cast<uint8_t>(1U << (y & 7));
}

void fillHeaderRect(int x0, int y0, int x1, int y1) {
  if (x0 > x1) {
    const int t = x0;
    x0 = x1;
    x1 = t;
  }
  if (y0 > y1) {
    const int t = y0;
    y0 = y1;
    y1 = t;
  }
  for (int y = y0; y <= y1; ++y) {
    for (int x = x0; x <= x1; ++x) {
      setHeaderPixel(x, y);
    }
  }
}

